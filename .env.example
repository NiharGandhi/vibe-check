# Vibe Check - API Keys (obtain from respective developer portals)
# At least one of Google or Foursquare is required for place discovery.
# Yelp has no UAE coverage; Reddit is unavailable in UAE - both excluded when region=uae.

# Region: "uae" (default for UAE/Dubai) or "default" (global, includes Yelp)
REGION=uae

# Google Places API (New) - https://console.cloud.google.com/
GOOGLE_PLACES_API_KEY=

# Foursquare Places API - https://foursquare.com/developers/signup
FOURSQUARE_API_KEY=

# Yelp Fusion API - https://www.yelp.com/developers/v3/manage_app
YELP_API_KEY=

# BestTime.app - Real-time live foot traffic (lively/quiet) - https://besttime.app/
BESTTIME_API_KEY=

# Reddit API (optional; not used when region=uae) - https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=vibe-check/1.0

# Optional: Google Places language (e.g. ar for Arabic in UAE)
# GOOGLE_LANGUAGE_CODE=ar

# Optional: cache TTL in seconds (default 300)
# CACHE_TTL_SECONDS=300
